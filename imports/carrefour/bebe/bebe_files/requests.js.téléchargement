    /**
     * Add product to wishlist
     * Update buttons
     * Update view
     */
    function addToWishlist(element, form) {
        let FavoriteNumberBadge = $('#partial_favorite .badge-items').html();

        $.ajax({
            type: 'POST',
            url: form.attr('action'),
            data: form.serialize(),
            beforeSend: _ => {
